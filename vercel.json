{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "simcolgroup.com" }],
      "destination": "https://www.simcolgroup.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/blog/(.*)",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    }
  ]
}